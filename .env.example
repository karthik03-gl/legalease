# ─────────────────────────────────────────────────────────────
#  LegalEase — Environment Variables
#  Copy this file → rename to .env.local → fill in your values
# ─────────────────────────────────────────────────────────────

# ── Google Gemini AI (FREE) ──────────────────────────────────
# Get at: https://aistudio.google.com/apikey
REACT_APP_GEMINI_API_KEY=AIzaSyYour-Gemini-Key-Here

# ── Firebase (FREE) ──────────────────────────────────────────
# Get at: https://console.firebase.google.com
# Create project → Add Web App → copy config values below
REACT_APP_FIREBASE_API_KEY=AIzaSyYour-Firebase-Key
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-id
REACT_APP_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=123456789
REACT_APP_FIREBASE_APP_ID=1:123456789:web:abcdef

# ── EmailJS — for OTP emails (FREE: 200 emails/month) ────────
# Get at: https://www.emailjs.com
# Create account → Email Services → Email Templates
REACT_APP_EMAILJS_SERVICE_ID=service_xxxxxxx
REACT_APP_EMAILJS_TEMPLATE_ID=template_xxxxxxx
REACT_APP_EMAILJS_PUBLIC_KEY=your_public_key
